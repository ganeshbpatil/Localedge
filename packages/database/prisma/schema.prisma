// LocalEdge - India's AI-powered hyperlocal business growth platform
// Prisma Schema v1.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum TenantPlan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  BUSINESS_OWNER
  MANAGER
  STAFF
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum BusinessStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_REVIEW
}

enum BusinessCategory {
  RESTAURANT
  RETAIL
  SALON
  GYM
  CLINIC
  PHARMACY
  GROCERY
  ELECTRONICS
  CLOTHING
  JEWELLERY
  REAL_ESTATE
  EDUCATION
  HOTEL
  TRAVEL
  AUTOMOTIVE
  FINANCE
  LEGAL
  ENTERTAINMENT
  SERVICES
  OTHER
}

enum ReviewPlatform {
  GOOGLE
  FACEBOOK
  ZOMATO
  SWIGGY
  JUSTDIAL
  SULEKHA
  YELP
  TRIPADVISOR
  INTERNAL
}

enum ReviewStatus {
  PENDING
  REPLIED
  IGNORED
  FLAGGED
}

enum SentimentType {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum WAConversationStatus {
  OPEN
  RESOLVED
  PENDING
  BOT
}

enum WAMessageDirection {
  INBOUND
  OUTBOUND
}

enum WAMessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum WACampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

enum WATemplateStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WATemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum DiscountType {
  PERCENTAGE
  FLAT
  BUY_X_GET_Y
  FREE_ITEM
}

enum OfferStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  DRAFT
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  EXPIRE
  ADJUST
  BONUS
}

enum QRCodeType {
  REVIEW
  WHATSAPP
  PAYMENT
  MENU
  OFFER
  LOYALTY
  WIFI
  CUSTOM
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentCurrency {
  INR
  USD
}

enum AIProviderName {
  OPENAI
  ANTHROPIC
  GEMINI
  GROQ
  DEEPSEEK
  MISTRAL
  OLLAMA
  AZURE_OPENAI
  COHERE
}

enum ProviderType {
  WHATSAPP
  AI
  PAYMENT
  SMS
  EMAIL
  MAPS
  STORAGE
  PUSH
}

enum WhatsAppProviderName {
  META_CLOUD
  TWILIO
  GUPSHUP
  INTERAKT
  AISENSY
  DIALOG360
}

enum PaymentProviderName {
  RAZORPAY
  CASHFREE
  PHONEPE
  STRIPE
  PAYTM
}

enum SMSProviderName {
  MSG91
  TWILIO
  FAST2SMS
  EXOTEL
}

enum EmailProviderName {
  RESEND
  MAILGUN
  SENDGRID
  SES
  POSTMARK
}

enum StorageProviderName {
  CLOUDFLARE_R2
  AWS_S3
  GCS
  BACKBLAZE
}

enum MapsProviderName {
  GOOGLE_MAPS
  MAPBOX
  OPENSTREETMAP
}

enum PushProviderName {
  FIREBASE
  ONESIGNAL
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
  EXPIRED
}

enum VerificationType {
  GST
  PAN
  AADHAAR
  BUSINESS_LICENSE
  FSSAI
  GBP
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum WebhookEventType {
  REVIEW_RECEIVED
  REVIEW_REPLIED
  WHATSAPP_MESSAGE_RECEIVED
  WHATSAPP_CAMPAIGN_COMPLETED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  CUSTOMER_CREATED
  OFFER_REDEEMED
  LOYALTY_POINTS_EARNED
  QR_SCANNED
  BUSINESS_CREATED
  SUBSCRIPTION_CHANGED
}

enum ReviewCampaignTriggerType {
  AFTER_PAYMENT
  AFTER_VISIT
  AFTER_ORDER
  MANUAL
  SCHEDULED
}

enum FlowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum PromotionType {
  CROSS_SELL
  REFERRAL
  JOINT_OFFER
  AREA_PROMOTION
}

enum CrossPromotionStatus {
  PENDING
  ACTIVE
  REJECTED
  COMPLETED
}

// ============================================================
// CORE ENTITIES
// ============================================================

model Tenant {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  plan           TenantPlan @default(FREE)
  settings       Json       @default("{}")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  // Relations
  users              User[]
  businesses         Business[]
  whatsappConfigs    WhatsAppConfig[]
  aiProviderConfigs  AIProviderConfig[]
  aiRoutingRules     AIRoutingRule[]
  aiUsageLogs        AIUsageLog[]
  featureFlags       FeatureFlag[]
  providerConfigs    ProviderConfig[]
  paymentConfigs     PaymentConfig[]
  plans              Subscription[]
  webhooks           Webhook[]

  @@map("tenants")
}

model User {
  id        String     @id @default(cuid())
  tenantId  String     @map("tenant_id")
  email     String?
  phone     String?
  name      String
  role      UserRole   @default(STAFF)
  status    UserStatus @default(PENDING_VERIFICATION)
  avatarUrl String?    @map("avatar_url")
  metadata  Json       @default("{}")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff     Staff[]
  managedBranches Branch[]

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([email])
  @@index([phone])
  @@map("users")
}

model Business {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  name            String
  slug            String
  category        BusinessCategory @default(OTHER)
  description     String?
  address         String
  city            String
  state           String
  pincode         String
  lat             Decimal?         @db.Decimal(10, 8)
  lng             Decimal?         @db.Decimal(11, 8)
  phone           String?
  email           String?
  website         String?
  gstin           String?
  pan             String?
  logoUrl         String?          @map("logo_url")
  coverUrl        String?          @map("cover_url")
  status          BusinessStatus   @default(ACTIVE)
  gbpLocationId   String?          @map("gbp_location_id")
  gbpSyncEnabled  Boolean          @default(false) @map("gbp_sync_enabled")
  gbpLastSyncAt   DateTime?        @map("gbp_last_sync_at")
  settings        Json             @default("{}")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branches            Branch[]
  staff               Staff[]
  customers           Customer[]
  reviews             Review[]
  reviewCampaigns     ReviewCampaign[]
  whatsappTemplates   WhatsAppTemplate[]
  whatsappConversations WhatsAppConversation[]
  whatsappCampaigns   WhatsAppCampaign[]
  whatsappFlows       WhatsAppFlow[]
  offers              Offer[]
  loyaltyPrograms     LoyaltyProgram[]
  loyaltyTransactions LoyaltyTransaction[]
  qrCodes             QRCode[]
  payments            Payment[]
  paymentTriggers     PaymentTrigger[]
  paymentTriggerLogs  PaymentTriggerLog[]
  paymentConfigs      PaymentConfig[]
  analytics           BusinessAnalytic[]
  events              Event[]
  verifications       BusinessVerification[]
  crossPromotions     CrossPromotion[]       @relation("BusinessCrossPromotions")
  crossPromotionPartners CrossPromotion[]    @relation("PartnerCrossPromotions")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([lat, lng])
  @@map("businesses")
}

model Branch {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  name       String
  address    String
  city       String
  lat        Decimal? @db.Decimal(10, 8)
  lng        Decimal? @db.Decimal(11, 8)
  phone      String?
  managerId  String?  @map("manager_id")
  isActive   Boolean  @default(true) @map("is_active")
  settings   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  manager   User?    @relation(fields: [managerId], references: [id])

  @@index([businessId])
  @@map("branches")
}

model Staff {
  id          String   @id @default(cuid())
  businessId  String   @map("business_id")
  userId      String   @map("user_id")
  role        String
  permissions Json     @default("[]")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId])
  @@map("staff")
}

model Customer {
  id             String    @id @default(cuid())
  businessId     String    @map("business_id")
  name           String
  phone          String?
  email          String?
  tags           Json      @default("[]")
  metadata       Json      @default("{}")
  loyaltyPoints  Int       @default(0) @map("loyalty_points")
  totalSpend     Decimal   @default(0) @db.Decimal(12, 2) @map("total_spend")
  visitCount     Int       @default(0) @map("visit_count")
  lastVisitAt    DateTime? @map("last_visit_at")
  isBlocked      Boolean   @default(false) @map("is_blocked")
  waId           String?   @map("wa_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  business            Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversations       WhatsAppConversation[]
  loyaltyTransactions LoyaltyTransaction[]
  payments            Payment[]
  couponUses          Coupon[]

  @@unique([businessId, phone])
  @@index([businessId])
  @@index([businessId, phone])
  @@map("customers")
}

// ============================================================
// REVIEW SYSTEM
// ============================================================

model Review {
  id            String        @id @default(cuid())
  businessId    String        @map("business_id")
  platform      ReviewPlatform
  externalId    String?       @map("external_id")
  authorName    String        @map("author_name")
  authorPhoto   String?       @map("author_photo")
  rating        Int
  content       String?
  reply         String?
  repliedAt     DateTime?     @map("replied_at")
  sentiment     SentimentType?
  aiReplyDraft  String?       @map("ai_reply_draft")
  status        ReviewStatus  @default(PENDING)
  reviewedAt    DateTime      @map("reviewed_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, platform, externalId])
  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, platform])
  @@index([businessId, rating])
  @@map("reviews")
}

model ReviewCampaign {
  id              String                    @id @default(cuid())
  businessId      String                    @map("business_id")
  name            String
  triggerType     ReviewCampaignTriggerType @map("trigger_type")
  messageTemplate String                    @map("message_template")
  isActive        Boolean                   @default(true) @map("is_active")
  stats           Json                      @default("{\"sent\": 0, \"opened\": 0, \"clicked\": 0, \"reviews\": 0}")
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("review_campaigns")
}

// ============================================================
// WHATSAPP
// ============================================================

model WhatsAppConfig {
  id             String               @id @default(cuid())
  tenantId       String               @map("tenant_id")
  provider       WhatsAppProviderName
  providerConfig Json                 @map("provider_config") // encrypted API keys
  phoneNumber    String               @map("phone_number")
  displayName    String?              @map("display_name")
  status         String               @default("ACTIVE")
  isDefault      Boolean              @default(false) @map("is_default")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("whatsapp_configs")
}

model WhatsAppTemplate {
  id                 String              @id @default(cuid())
  businessId         String              @map("business_id")
  name               String
  category           WATemplateCategory
  language           String              @default("en")
  components         Json                // header, body, footer, buttons
  status             WATemplateStatus    @default(PENDING)
  providerTemplateId String?             @map("provider_template_id")
  rejectionReason    String?             @map("rejection_reason")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  // Relations
  business  Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaigns WhatsAppCampaign[]

  @@unique([businessId, name, language])
  @@index([businessId])
  @@map("whatsapp_templates")
}

model WhatsAppConversation {
  id            String               @id @default(cuid())
  businessId    String               @map("business_id")
  customerId    String?              @map("customer_id")
  waId          String               @map("wa_id") // WhatsApp phone number
  status        WAConversationStatus @default(OPEN)
  lastMessageAt DateTime?            @map("last_message_at")
  assignedTo    String?              @map("assigned_to")
  metadata      Json                 @default("{}")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  // Relations
  business  Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer  Customer?         @relation(fields: [customerId], references: [id])
  messages  WhatsAppMessage[]

  @@unique([businessId, waId])
  @@index([businessId])
  @@index([businessId, status])
  @@map("whatsapp_conversations")
}

model WhatsAppMessage {
  id             String             @id @default(cuid())
  conversationId String             @map("conversation_id")
  direction      WAMessageDirection
  content        Json               // {type: text|image|template|..., body: ...}
  status         WAMessageStatus    @default(QUEUED)
  waMessageId    String?            @map("wa_message_id")
  errorMessage   String?            @map("error_message")
  sentAt         DateTime?          @map("sent_at")
  deliveredAt    DateTime?          @map("delivered_at")
  readAt         DateTime?          @map("read_at")
  createdAt      DateTime           @default(now()) @map("created_at")

  // Relations
  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([waMessageId])
  @@map("whatsapp_messages")
}

model WhatsAppCampaign {
  id             String            @id @default(cuid())
  businessId     String            @map("business_id")
  name           String
  templateId     String            @map("template_id")
  audienceFilter Json              @map("audience_filter") // filter rules for customers
  status         WACampaignStatus  @default(DRAFT)
  scheduledAt    DateTime?         @map("scheduled_at")
  startedAt      DateTime?         @map("started_at")
  completedAt    DateTime?         @map("completed_at")
  stats          Json              @default("{\"total\": 0, \"sent\": 0, \"delivered\": 0, \"read\": 0, \"failed\": 0, \"replied\": 0}")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  // Relations
  business Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  template WhatsAppTemplate  @relation(fields: [templateId], references: [id])

  @@index([businessId])
  @@index([businessId, status])
  @@map("whatsapp_campaigns")
}

model WhatsAppFlow {
  id         String     @id @default(cuid())
  businessId String     @map("business_id")
  name       String
  trigger    Json       // {type: keyword|event|..., config: ...}
  nodes      Json       // flow node graph
  status     FlowStatus @default(DRAFT)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("whatsapp_flows")
}

// ============================================================
// OFFERS & LOYALTY
// ============================================================

model Offer {
  id            String       @id @default(cuid())
  businessId    String       @map("business_id")
  title         String
  description   String?
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @db.Decimal(10, 2) @map("discount_value")
  minOrder      Decimal?     @db.Decimal(10, 2) @map("min_order")
  maxDiscount   Decimal?     @db.Decimal(10, 2) @map("max_discount")
  maxUses       Int?         @map("max_uses")
  usesCount     Int          @default(0) @map("uses_count")
  validFrom     DateTime     @map("valid_from")
  validTo       DateTime     @map("valid_to")
  terms         String?
  imageUrl      String?      @map("image_url")
  status        OfferStatus  @default(DRAFT)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  coupons  Coupon[]

  @@index([businessId])
  @@index([businessId, status])
  @@map("offers")
}

model Coupon {
  id         String    @id @default(cuid())
  offerId    String    @map("offer_id")
  code       String    @unique
  uses       Int       @default(0)
  maxUses    Int       @default(1) @map("max_uses")
  customerId String?   @map("customer_id")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  // Relations
  offer    Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([offerId])
  @@index([code])
  @@map("coupons")
}

model LoyaltyProgram {
  id               String   @id @default(cuid())
  businessId       String   @unique @map("business_id")
  name             String
  pointsPerRupee   Decimal  @db.Decimal(6, 4) @map("points_per_rupee")
  redemptionRate   Decimal  @db.Decimal(6, 4) @map("redemption_rate") // points per rupee value
  minRedemption    Int      @default(100) @map("min_redemption")
  maxRedemptionPct Int      @default(50) @map("max_redemption_pct") // max % of bill
  tiers            Json     @default("[]") // [{name, minPoints, benefits}]
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("loyalty_programs")
}

model LoyaltyTransaction {
  id          String                 @id @default(cuid())
  customerId  String                 @map("customer_id")
  businessId  String                 @map("business_id")
  points      Int
  type        LoyaltyTransactionType
  referenceId String?                @map("reference_id")
  description String?
  createdAt   DateTime               @default(now()) @map("created_at")

  // Relations
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([businessId])
  @@index([customerId, businessId])
  @@map("loyalty_transactions")
}

// ============================================================
// QR CODES
// ============================================================

model QRCode {
  id         String     @id @default(cuid())
  businessId String     @map("business_id")
  name       String
  type       QRCodeType
  targetUrl  String     @map("target_url")
  qrImageUrl String?    @map("qr_image_url")
  scanCount  Int        @default(0) @map("scan_count")
  settings   Json       @default("{}")
  isActive   Boolean    @default(true) @map("is_active")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("qr_codes")
}

// ============================================================
// PAYMENTS
// ============================================================

model PaymentConfig {
  id            String              @id @default(cuid())
  tenantId      String              @map("tenant_id")
  businessId    String?             @map("business_id")
  provider      PaymentProviderName
  config        Json                // encrypted provider credentials
  webhookSecret String?             @map("webhook_secret") // AES-256-GCM encrypted
  metadata      Json                @default("{}") // trigger settings: delayMinutes, cooldownHours, reviewLink, etc.
  isActive      Boolean             @default(false) @map("is_active")
  isDefault     Boolean             @default(false) @map("is_default")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([businessId])
  @@map("payment_configs")
}

model Payment {
  id                String          @id @default(cuid())
  businessId        String          @map("business_id")
  customerId        String?         @map("customer_id")
  amount            Decimal         @db.Decimal(12, 2)
  currency          PaymentCurrency @default(INR)
  status            PaymentStatus   @default(PENDING)
  provider          PaymentProviderName
  providerPaymentId String?         @map("provider_payment_id")
  providerOrderId   String?         @map("provider_order_id")
  description       String?
  metadata          Json            @default("{}")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  // Relations
  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([businessId])
  @@index([businessId, status])
  @@index([providerPaymentId])
  @@map("payments")
}

model PaymentTrigger {
  id           String   @id @default(cuid())
  businessId   String   @map("business_id")
  eventType    String   @map("event_type") // payment.success, payment.failed
  actionType   String   @map("action_type") // send_whatsapp, add_loyalty_points, send_review_request
  actionConfig Json     @map("action_config")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("payment_triggers")
}

model PaymentTriggerLog {
  id            String   @id @default(cuid())
  businessId    String   @map("business_id")
  customerPhone String   @map("customer_phone")
  paymentId     String   @map("payment_id")
  provider      String   // RAZORPAY | CASHFREE
  amountRupees  Decimal  @map("amount_rupees") @db.Decimal(12, 2)
  status        String   @default("PENDING") // PENDING | SENT | FAILED
  scheduledFor  DateTime @map("scheduled_for")
  sentAt        DateTime? @map("sent_at")
  waMessageId   String?  @map("wa_message_id")
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, customerPhone])
  @@index([status])
  @@map("payment_trigger_logs")
}

// ============================================================
// AI & PROVIDER CONFIGURATION
// ============================================================

model AIProviderConfig {
  id             String         @id @default(cuid())
  tenantId       String         @map("tenant_id")
  provider       AIProviderName
  apiKeyEncrypted String        @map("api_key_encrypted")
  baseUrl        String?        @map("base_url") // for Azure/Ollama
  modelDefaults  Json           @default("{}") @map("model_defaults")
  isActive       Boolean        @default(true) @map("is_active")
  priority       Int            @default(0) // lower = higher priority
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@map("ai_provider_configs")
}

model AIRoutingRule {
  id               String         @id @default(cuid())
  tenantId         String         @map("tenant_id")
  useCase          String         @map("use_case") // review_reply, sentiment_analysis, chat, etc.
  provider         AIProviderName
  model            String
  fallbackProvider AIProviderName? @map("fallback_provider")
  fallbackModel    String?         @map("fallback_model")
  maxCostPerToken  Decimal?        @db.Decimal(10, 8) @map("max_cost_per_token")
  isActive         Boolean         @default(true) @map("is_active")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, useCase])
  @@index([tenantId])
  @@map("ai_routing_rules")
}

model AIUsageLog {
  id          String         @id @default(cuid())
  tenantId    String         @map("tenant_id")
  businessId  String?        @map("business_id")
  provider    AIProviderName
  model       String
  useCase     String         @map("use_case")
  tokensIn    Int            @map("tokens_in")
  tokensOut   Int            @map("tokens_out")
  cost        Decimal        @db.Decimal(12, 8)
  latencyMs   Int            @map("latency_ms")
  success     Boolean
  errorMsg    String?        @map("error_msg")
  createdAt   DateTime       @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, useCase])
  @@index([tenantId, createdAt])
  @@map("ai_usage_logs")
}

model FeatureFlag {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  flagKey            String   @map("flag_key")
  isEnabled          Boolean  @default(false) @map("is_enabled")
  rolloutPercentage  Int      @default(100) @map("rollout_percentage")
  metadata           Json     @default("{}")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, flagKey])
  @@index([tenantId])
  @@map("feature_flags")
}

model ProviderConfig {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  providerType ProviderType @map("provider_type")
  providerName String    @map("provider_name")
  config       Json      // encrypted sensitive fields
  isActive     Boolean   @default(false) @map("is_active")
  isDefault    Boolean   @default(false) @map("is_default")
  priority     Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, providerType, providerName])
  @@index([tenantId])
  @@index([tenantId, providerType])
  @@map("provider_configs")
}

// ============================================================
// ANALYTICS & EVENTS
// ============================================================

model BusinessAnalytic {
  id          String   @id @default(cuid())
  businessId  String   @map("business_id")
  date        DateTime @db.Date
  metricType  String   @map("metric_type") // reviews_received, wa_messages_sent, etc.
  value       Decimal  @db.Decimal(12, 4)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date, metricType])
  @@index([businessId])
  @@index([businessId, date])
  @@index([businessId, metricType])
  @@map("business_analytics")
}

model Event {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  businessId String?  @map("business_id")
  eventType  String   @map("event_type")
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  payload    Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  business Business? @relation(fields: [businessId], references: [id])

  @@index([tenantId])
  @@index([businessId])
  @@index([tenantId, eventType])
  @@index([createdAt])
  @@map("events")
}

// ============================================================
// CROSS PROMOTION
// ============================================================

model CrossPromotion {
  id                String               @id @default(cuid())
  businessId        String               @map("business_id")
  partnerBusinessId String               @map("partner_business_id")
  type              PromotionType
  content           Json                 @default("{}")
  status            CrossPromotionStatus @default(PENDING)
  validFrom         DateTime?            @map("valid_from")
  validTo           DateTime?            @map("valid_to")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  // Relations
  business        Business @relation("BusinessCrossPromotions", fields: [businessId], references: [id], onDelete: Cascade)
  partnerBusiness Business @relation("PartnerCrossPromotions", fields: [partnerBusinessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([partnerBusinessId])
  @@map("cross_promotions")
}

model PromotionNetwork {
  id          String   @id @default(cuid())
  name        String
  description String?
  members     Json     @default("[]") // [{businessId, joinedAt}]
  rules       Json     @default("{}")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("promotion_networks")
}

// ============================================================
// SUBSCRIPTIONS & PLANS
// ============================================================

model Plan {
  id            String   @id @default(cuid())
  name          String   @unique
  priceMonthly  Decimal  @db.Decimal(10, 2) @map("price_monthly")
  priceYearly   Decimal  @db.Decimal(10, 2) @map("price_yearly")
  features      Json     @default("[]")
  limits        Json     @default("{}")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                    String             @id @default(cuid())
  tenantId              String             @map("tenant_id")
  planId                String             @map("plan_id")
  status                SubscriptionStatus @default(TRIALING)
  currentPeriodStart    DateTime           @map("current_period_start")
  currentPeriodEnd      DateTime           @map("current_period_end")
  cancelAtPeriodEnd     Boolean            @default(false) @map("cancel_at_period_end")
  paymentProviderSubId  String?            @map("payment_provider_sub_id")
  metadata              Json               @default("{}")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@map("subscriptions")
}

// ============================================================
// VERIFICATION
// ============================================================

model BusinessVerification {
  id           String             @id @default(cuid())
  businessId   String             @map("business_id")
  type         VerificationType
  status       VerificationStatus @default(PENDING)
  verifiedData Json               @default("{}") @map("verified_data")
  documents    Json               @default("[]") // uploaded doc URLs
  verifiedAt   DateTime?          @map("verified_at")
  expiresAt    DateTime?          @map("expires_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, type])
  @@index([businessId])
  @@map("business_verifications")
}

// ============================================================
// WEBHOOKS
// ============================================================

model Webhook {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  url       String
  events    Json     @default("[]") // WebhookEventType[]
  secret    String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@map("webhooks")
}

model WebhookDelivery {
  id             String   @id @default(cuid())
  webhookId      String   @map("webhook_id")
  eventType      String   @map("event_type")
  payload        Json
  responseStatus Int?     @map("response_status")
  responseBody   String?  @map("response_body")
  attempts       Int      @default(0)
  nextRetryAt    DateTime? @map("next_retry_at")
  succeededAt    DateTime? @map("succeeded_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([createdAt])
  @@map("webhook_deliveries")
}
