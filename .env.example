# =============================================================================
# LocalEdge Environment Variables
# Copy this file to .env and fill in the values
# NOTE: Provider API keys are stored in DB (provider_configs table), NOT here
# =============================================================================

# Database
DATABASE_URL="postgresql://localedge:localedge@localhost:5432/localedge"
MONGODB_URL="mongodb://localedge:localedge@localhost:27017/localedge"
REDIS_URL="redis://localhost:6379"
ELASTICSEARCH_URL="http://localhost:9200"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="your-refresh-token-secret"
REFRESH_TOKEN_EXPIRES_IN="30d"

# Encryption (for provider API keys stored in DB)
ENCRYPTION_KEY="32-char-hex-string-for-aes-256-gcm"

# App
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3002"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"
